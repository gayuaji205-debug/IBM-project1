            hotelData.forEach(booking => {
                const row = bookingsTable.insertRow();
                
                // Determine status badge based on arrival date
                const arrivalDate = new Date(booking['Arrival Date']);
                const today = new Date();
                let status, badgeClass;
                
                if (arrivalDate > today) {
                    status = 'Upcoming';
                    badgeClass = 'badge badge-warning';
                } else {
                    status = 'Completed';
                    badgeClass = 'badge badge-success';
                }

                // Format total bill as currency
                const totalBill = parseFloat(booking['Total Bill']).toLocaleString('en-IN', {
                    style: 'currency',
                    currency: 'INR',
                    maximumFractionDigits: 0
                });

                // Add cells to the row
                row.innerHTML = `
                    <td>${booking['Booking ID']}</td>
                    <td>${booking['Guest Name']}</td>
                    <td>${booking['Property Name']}</td>
                    <td>${booking['Room Type']}</td>
                    <td>${formatDate(booking['Arrival Date'])}</td>
                    <td>${formatDate(booking['Departure Date'])}</td>
                    <td>${totalBill}</td>
                    <td><span class="${badgeClass}">${status}</span></td>
                `;
            });
        }

        // Format date as DD/MM/YYYY
        function formatDate(dateString) {
            const date = new Date(dateString);
            return date.toLocaleDateString('en-GB'); // DD/MM/YYYY format
        }

        // Initialize Charts
        function initializeCharts() {
            // Revenue by Property Chart
            const revenueCtx = document.getElementById('revenue-chart').getContext('2d');
            
            // Group revenue by property
            const revenueByProperty = {};
            hotelData.forEach(booking => {
                const property = booking['Property Name'];
                const revenue = parseFloat(booking['Total Bill']);
                
                if (!revenueByProperty[property]) {
                    revenueByProperty[property] = 0;
                }
                revenueByProperty[property] += revenue;
            });

            const revenueChart = new Chart(revenueCtx, {
                type: 'bar',
                data: {
                    labels: Object.keys(revenueByProperty),
                    datasets: [{
                        label: 'Revenue (₹)',
                        data: Object.values(revenueByProperty),
                        backgroundColor: [
                            'rgba(52, 152, 219, 0.7)',
                            'rgba(155, 89, 182, 0.7)',
                            'rgba(46, 204, 113, 0.7)',
                            'rgba(241, 196, 15, 0.7)',
                            'rgba(231, 76, 60, 0.7)',
                            'rgba(26, 188, 156, 0.7)'
                        ],
                        borderColor: [
                            'rgba(52, 152, 219, 1)',
                            'rgba(155, 89, 182, 1)',
                            'rgba(46, 204, 113, 1)',
                            'rgba(241, 196, 15, 1)',
                            'rgba(231, 76, 60, 1)',
                            'rgba(26, 188, 156, 1)'
                        ],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) {
                                    return '₹' + value.toLocaleString();
                                }
                            }
                        }
                    },
                    plugins: {
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return 'Revenue: ₹' + context.raw.toLocaleString();
                                }
                            }
                        }
                    }
                }
            });

            // Bookings by Channel Chart
            const channelCtx = document.getElementById('channel-chart').getContext('2d');
            
            // Group bookings by channel
            const bookingsByChannel = {};
            hotelData.forEach(booking => {
                const channel = booking['Booking Channel'];
                
                if (!bookingsByChannel[channel]) {
                    bookingsByChannel[channel] = 0;
                }
                bookingsByChannel[channel]++;
            });

            const channelChart = new Chart(channelCtx, {
                type: 'pie',
                data: {
                    labels: Object.keys(bookingsByChannel),
                    datasets: [{
                        data: Object.values(bookingsByChannel),
                        backgroundColor: [
                            'rgba(52, 152, 219, 0.7)',
                            'rgba(155, 89, 182, 0.7)',
                            'rgba(46, 204, 113, 0.7)',
                            'rgba(241, 196, 15, 0.7)'
                        ],
                        borderColor: [
                            'rgba(52, 152, 219, 1)',
                            'rgba(155, 89, 182, 1)',
                            'rgba(46, 204, 113, 1)',
                            'rgba(241, 196, 15, 1)'
                        ],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'right',
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    const label = context.label || '';
                                    const value = context.raw || 0;
                                    const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                    const percentage = Math.round((value / total) * 100);
                                    return `${label}: ${value} (${percentage}%)`;
                                }
                            }
                        }
                    }
                }
            });
        }

        // Filter functionality (would be implemented in a real app)
        document.getElementById('property-filter').addEventListener('change', function() {
            // In a real app, this would filter the data and update the table and charts
            console.log('Filter by property:', this.value);
        });

        document.getElementById('room-type-filter').addEventListener('change', function() {
            // In a real app, this would filter the data and update the table and charts
            console.log('Filter by room type:', this.value);
        });

        document.getElementById('date-range-filter').addEventListener('change', function() {
            // In a real app, this would filter the data and update the table and charts
            console.log('Filter by date range:', this.value);
        });
    </script>
</body>
