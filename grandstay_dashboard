                <li><a href="#"><i>📍</i> Properties</a></li>
                <li><a href="#"><i>⭐</i> Reviews</a></li>
                <li><a href="#"><i>⚙️</i> Settings</a></li>
            </ul>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <div class="container">
                <div class="page-header">
                    <h2>Dashboard Overview</h2>
                    <div>
                        <span id="current-date"></span>
                    </div>
                </div>

                <!-- Stats Cards -->
                <div class="stats-cards">
                    <div class="stat-card">
                        <h3>Total Bookings</h3>
                        <div class="value" id="total-bookings">200</div>
                        <div class="description">This month: +15%</div>
                    </div>
                    <div class="stat-card">
                        <h3>Total Revenue</h3>
                        <div class="value" id="total-revenue">₹12.5M</div>
                        <div class="description">This month: +8%</div>
                    </div>
                    <div class="stat-card">
                        <h3>Average Rating</h3>
                        <div class="value" id="avg-rating">6.8</div>
                        <div class="description">Out of 10</div>
                    </div>
                    <div class="stat-card">
                        <h3>Occupancy Rate</h3>
                        <div class="value" id="occupancy-rate">82%</div>
                        <div class="description">+5% from last month</div>
                    </div>
                </div>

                <!-- Filters -->
                <div class="card">
                    <div class="filter-bar">
                        <div class="filter-group">
                            <label for="property-filter">Property</label>
                            <select id="property-filter">
                                <option value="all">All Properties</option>
                                <option value="GrandStay Goa">GrandStay Goa</option>
                                <option value="GrandStay Jaipur">GrandStay Jaipur</option>
                                <option value="GrandStay Delhi">GrandStay Delhi</option>
                                <option value="GrandStay Bengaluru">GrandStay Bengaluru</option>
                                <option value="GrandStay Mumbai">GrandStay Mumbai</option>
                                <option value="GrandStay Chennai">GrandStay Chennai</option>
                            </select>
                        </div>
                        <div class="filter-group">
                            <label for="room-type-filter">Room Type</label>
                            <select id="room-type-filter">
                                <option value="all">All Room Types</option>
                                <option value="Standard">Standard</option>
                                <option value="Deluxe">Deluxe</option>
                                <option value="Suite">Suite</option>
                            </select>
                        </div>
                        <div class="filter-group">
                            <label for="date-range-filter">Date Range</label>
                            <select id="date-range-filter">
                                <option value="all">All Dates</option>
                                <option value="this-month">This Month</option>
                                <option value="last-month">Last Month</option>
                                <option value="this-quarter">This Quarter</option>
                                <option value="custom">Custom Range</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Recent Bookings -->
                <div class="card">
                    <div class="card-header">
                        <h3>Recent Bookings</h3>
                        <button class="btn">View All</button>
                    </div>
                    <div class="table-responsive">
                        <table id="bookings-table">
                            <thead>
                                <tr>
                                    <th>Booking ID</th>
                                    <th>Guest Name</th>
                                    <th>Property</th>
                                    <th>Room Type</th>
                                    <th>Check-In</th>
                                    <th>Check-Out</th>
                                    <th>Total Bill</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Data will be populated by JavaScript -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Charts Row -->
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                    <!-- Revenue by Property -->
                    <div class="card">
                        <div class="card-header">
                            <h3>Revenue by Property</h3>
                        </div>
                        <div class="chart-container">
                            <canvas id="revenue-chart"></canvas>
                        </div>
                    </div>

                    <!-- Bookings by Channel -->
                    <div class="card">
                        <div class="card-header">
                            <h3>Bookings by Channel</h3>
                        </div>
                        <div class="chart-container">
                            <canvas id="channel-chart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

